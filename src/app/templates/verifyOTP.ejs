<!DOCTYPE html>
<html>
  <head>
    <style>
      body {
        font-family: sans-serif;
        line-height: 1.6;
        color: #333;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
        border: 1px solid #eee;
        border-radius: 10px;
      }
      .otp {
        font-size: 2em;
        font-weight: bold;
        letter-spacing: 5px;
        color: #6366f1;
        text-align: center;
        margin: 20px 0;
      }
      .footer {
        margin-top: 20px;
        font-size: 0.8em;
        color: #777;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h2>Verify Your Email</h2>
      <p>Hello,</p>
      <p>
        Thank you for choosing Rangdhanu IT. Use the following OTP to verify
        your email address:
      </p>
      <div class="otp"><%= otp %></div>
      <p>
        This code will expire in 1 hour. Do not share this code with anyone.
      </p>
      <div class="footer">
        <p>&copy; 2026 Rangdhanu IT. All rights reserved.</p>
      </div>
    </div>
  </body>
</html>
